{
  "name": "product-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:develop": "cross-env NODE_ENV=development node build.js",
    "build:staging": "cross-env NODE_ENV=staging node build.js",
    "build:produ": "cross-env NODE_ENV=production node build.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:develop": "cross-env NODE_ENV=development nest start",
    "start:staging": "cross-env NODE_ENV=staging node dist/main.js",
    "start:produ": "cross-env NODE_ENV=production node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "seed": "ts-node -r tsconfig-paths/register src/seed.ts",
    "seed:roles": "npm run seed -- roles",
    "seed:users": "npm run seed -- users",
    "seed:products": "npm run seed -- products",
    "seed:all": "npm run seed -- all",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^4.0.0",
    "@types/nodemailer": "^8.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.76.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "mongoose": "^8.23.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typescript-eslint": "^8.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^17.5.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
